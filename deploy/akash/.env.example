# deploy/akash/.env.example
# Copy to .env and fill in REAL values. NEVER commit the real .env.
# This file contains placeholders only.

# ---------------------------------------------------------------------------
# Akash CLI configuration
# ---------------------------------------------------------------------------
AKASH_KEY_NAME=wallet
AKASH_CHAIN_ID=akashnet-2
AKASH_NODE=https://rpc.akashnet.net:443
AKASH_KEYRING_BACKEND=test
AKASH_HOME=/root/.akash
AKASH_BROADCAST_MODE=block
# Resolved automatically from AKASH_KEY_NAME — listed here for reference:
AKASH_ACCOUNT_ADDRESS=

# ---------------------------------------------------------------------------
# GHCR (GitHub Container Registry)
# ---------------------------------------------------------------------------
# GitHub username or org that owns the package.
GHCR_USER=your-github-username
# GitHub Personal Access Token with `write:packages` scope (build-and-push.sh)
# and `read:packages` for Akash providers to pull (package must be PUBLIC).
CR_PAT=ghp_replace_with_your_token
# Immutable image tag to deploy (e.g. sha-a1b2c3d). Avoid `latest` in prod.
IMAGE_TAG=latest

# ---------------------------------------------------------------------------
# Vouch runtime secrets — injected at deploy time, never baked into the image.
# ---------------------------------------------------------------------------
VENICE_API_KEY=replace_with_your_venice_key
THREE_WS_API_KEY=replace_with_your_threews_key
