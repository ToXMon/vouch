# ─── Vouch Frontend Environment Variables ───
# Copy to .env.local and fill with real values. Never commit .env.local.

# Agent Runtime (FastAPI) — AI spec generation, evidence audit, dispute adjudication
VITE_AGENT_URL=http://localhost:8000

# Monad Testnet RPC
VITE_MONAD_RPC_URL=https://testnet-rpc.monad.xyz

# Vouch.sol contract address (fill after deploy)
VITE_VOUCH_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# Para API key (public key from para keys get — safe for frontend)
VITE_PARA_API_KEY=your_para_public_api_key_here

# Para environment: "beta" or "production"
VITE_PARA_ENVIRONMENT=beta
